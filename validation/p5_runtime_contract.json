  "network_contract": {
    "trust_env_false_required": true,
    "proxy_env_expected_absent_in_checked_terminal": true,
    "opensearch_local_https_skip_tls_verify": true,
    "google_drive_depends_on_tun_or_vpn_or_network_condition": true
