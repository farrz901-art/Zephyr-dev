# Repo-owned P4.5 template only.
# Real local/live validation should load env files from:
#   ${ZEPHYR_P45_HOME}/env/.env
#   ${ZEPHYR_P45_HOME}/env/.env.p45
#   ${ZEPHYR_P45_HOME}/env/.env.p45.local
# The runtime plane rooted at ${ZEPHYR_P45_HOME} should also own:
#   ${ZEPHYR_P45_HOME}/docker-compose.yml
#   ${ZEPHYR_P45_HOME}/logs/
#   ${ZEPHYR_P45_HOME}/data/
# Repo-root `.env`, `.env.p45`, and `.env.p45.local` remain fallback/bootstrap inputs only.
# OS environment still has the highest precedence.

# Shared validation substrate
ZEPHYR_P45_POSTGRES_HOST=127.0.0.1
ZEPHYR_P45_POSTGRES_PORT=15432
ZEPHYR_P45_POSTGRES_USER=zephyr
ZEPHYR_P45_POSTGRES_PASSWORD=zephyr
ZEPHYR_P45_POSTGRES_DB=zephyr

